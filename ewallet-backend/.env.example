# ─────────────────────────────────────────────
#  Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ewallet_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_SSL=false

# ─────────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ─────────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=5m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1h
JWT_ADMIN_REFRESH_EXPIRES_IN=8h

# ─────────────────────────────────────────────
#  Security
# ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
#  Fraud Detection
# ─────────────────────────────────────────────
FRAUD_SCORE_THRESHOLD=60
FRAUD_LARGE_TXN_AMOUNT=5000
FRAUD_AI_ENABLED=true

# ─────────────────────────────────────────────
#  Seed Admin (used in adminSeed.js)
# ─────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@ewallet.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
SEED_ADMIN_PHONE=+905000000000

# ─────────────────────────────────────────────
#  stripe key
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ─────────────────────────────────────────────
#  GROQ_API_KEY
# ─────────────────────────────────────────────
GROQ_MODEL_ID=openai/gpt-oss-120b
GROQ_API_KEY=your_groq_api_key_here


# ---------------------------------------------
#  Email (Nodemailer / Gmail)
#  SMTP_PASS = 16-char Gmail App Password
#  Generate at: Google Account > Security > 2-Step > App Passwords
# ---------------------------------------------
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=E-Wallet
MOCK_GEO_IP=78.171.94.202
